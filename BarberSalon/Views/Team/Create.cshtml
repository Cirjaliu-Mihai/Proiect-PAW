@model BarberSalon.Models.Worker
@{
    ViewData["Title"] = "Adaugă Membru";
}

@section CustomStyles {
    <link rel="stylesheet" href="~/css/team.css" asp-append-version="true" />
}

<section class="team py-5 bg-light">
    <div class="container">
        <div class="row">
            <div class="col-md-6 offset-md-3">
                <div class="card p-4">
                    <h4 class="mb-4">Adaugă Membru Nou</h4>

                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Nume</label>
                            <input asp-for="Name" class="form-control" placeholder="ex: Ion Popescu" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Position" class="form-label">Poziție</label>
                            <input asp-for="Position" class="form-control" placeholder="ex: Frizer Senior" />
                            <span asp-validation-for="Position" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label">Telefon</label>
                            <input asp-for="PhoneNumber" type="number" class="form-control" placeholder="07xxxxxxxx" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label">Adresă</label>
                            <input asp-for="Address" class="form-control"
                                   placeholder="ex: Strada Primaverii, Craiova" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="HireDate" class="form-label">Data Angajării</label>
                            <input asp-for="HireDate" type="date" class="form-control" />
                            <span asp-validation-for="HireDate" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label for="photo" class="form-label">Fotografie</label>
                            <input type="file" id="photo" name="photo" class="form-control"
                                   accept=".jpg,.jpeg,.png,.webp" />
                            <small class="text-muted">Acceptat: .jpg, .jpeg, .png, .webp</small>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-save me-1"></i> Salvează
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-times me-1"></i> Anulează
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
