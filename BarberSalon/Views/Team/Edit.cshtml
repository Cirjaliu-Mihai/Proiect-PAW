@model BarberSalon.Models.Worker
@{
    ViewData["Title"] = "Editează Membru";
}

@section CustomStyles {
    <link rel="stylesheet" href="~/css/team.css" asp-append-version="true" />
}

<section class="team py-5 bg-light">
    <div class="container">
        <div class="row">
            <div class="col-md-6 offset-md-3">
                <div class="card p-4">
                    <h4 class="mb-4">Editează Membru</h4>

                    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="PhotoPath" />

                        <div class="mb-3 text-center">
                            <img src="@Model.PhotoPath" alt="@Model.Name"
                                 style="width:100px;height:100px;object-fit:cover;border-radius:50%;" class="mb-2" />
                            <div>
                                <label for="photo" class="form-label d-block">Schimbă fotografia</label>
                                <input type="file" id="photo" name="photo" class="form-control"
                                       accept=".jpg,.jpeg,.png,.webp" />
                                <small class="text-muted">Lasă gol pentru a păstra fotografia actuală.</small>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Nume</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Position" class="form-label">Poziție</label>
                            <input asp-for="Position" class="form-control" />
                            <span asp-validation-for="Position" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label">Telefon</label>
                            <input asp-for="PhoneNumber" type="number" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label">Adresă</label>
                            <input asp-for="Address" class="form-control" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="HireDate" class="form-label">Data Angajării</label>
                            <input asp-for="HireDate" type="date" class="form-control" />
                            <span asp-validation-for="HireDate" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-save me-1"></i> Salvează
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-times me-1"></i> Anulează
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
