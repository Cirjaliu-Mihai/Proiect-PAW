@model BarberSalon.Models.Appointment

@{
    ViewData["Title"] = "Detalii Programare";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Detalii Appointment</h5>
                <hr />
                <dl class="row">
                    <dt class="col-sm-4">ID Utilizator:</dt>
                    <dd class="col-sm-8">@Model.UserId</dd>

                    <dt class="col-sm-4">Serviciu:</dt>
                    <dd class="col-sm-8">@Model.Service.Name</dd>

                    <dt class="col-sm-4">Frizer:</dt>
                    <dd class="col-sm-8">@Model.Worker.Name</dd>

                    <dt class="col-sm-4">Data Programării:</dt>
                    <dd class="col-sm-8">@Model.AppointmentDate.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-sm-4">Ora:</dt>
                    <dd class="col-sm-8">@Model.AppointmentTime.ToString("HH:mm")</dd>

                    <dt class="col-sm-4">Status:</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-info">@Model.Status</span>
                    </dd>

                    <dt class="col-sm-4">Creat:</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                    @if (Model.UpdatedAt.HasValue)
                    {
                        <dt class="col-sm-4">Actualizat:</dt>
                        <dd class="col-sm-8">@Model.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</dd>
                    }
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Editează</a>
    <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-danger">Șterge</a>
    <a asp-action="Index" class="btn btn-secondary">Înapoi la Listă</a>
</div>
