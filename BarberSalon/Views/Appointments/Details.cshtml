@model BarberSalon.Models.Appointment

@{
    ViewData["Title"] = "Detalii Programare";
}

@section CustomStyles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/appointments.css" asp-append-version="true" />
}

<section class="appointments-section py-5">
    <div class="container">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <h2 class="mb-4">
                    <i class="fas fa-info-circle"></i> Detalii Programare
                </h2>

                <div class="booking-card">
                    <div class="booking-header">
                        <span class="booking-service">@Model.Service?.Name</span>
                        <span class="booking-status @Model.Status.ToString().ToLower()">
                            @(Model.Status.ToString() == "Confirmed" ? "Confirmată" :
                              Model.Status.ToString() == "Canceled" ? "Anulată" :
                              Model.Status.ToString() == "Finalized" ? "Finalizată" :
                              Model.Status.ToString())
                        </span>
                    </div>

                    <div class="booking-details mb-3">
                        <p>
                            <i class="fas fa-calendar-alt"></i>
                            <strong>Data:</strong> @Model.AppointmentDate.ToString("dddd, dd MMMM yyyy")
                        </p>
                        <p>
                            <i class="fas fa-clock"></i>
                            <strong>Ora:</strong> @Model.AppointmentTime.ToString("HH:mm")
                        </p>
                        <p>
                            <i class="fas fa-user"></i>
                            <strong>Frizer:</strong> @Model.Worker?.Name
                        </p>
                        <p>
                            <i class="fas fa-tag"></i>
                            <strong>Preț:</strong> @Model.Service?.Price RON
                        </p>
                        <p>
                            <i class="fas fa-calendar-check"></i>
                            <strong>Creat:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                        </p>
                        @if (Model.UpdatedAt.HasValue)
                        {
                            <p>
                                <i class="fas fa-sync"></i>
                                <strong>Actualizat:</strong> @Model.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")
                            </p>
                        }
                    </div>

                    <div class="booking-actions">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning">
                            <i class="fas fa-edit"></i> Editează
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                            <i class="fas fa-trash"></i> Șterge
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left"></i> Înapoi
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
