@model BarberSalon.Models.Appointment

@{
    ViewData["Title"] = "Șterge Programare";
}

@section CustomStyles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/appointments.css" asp-append-version="true" />
}

<section class="appointments-section py-5">
    <div class="container">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <h2 class="mb-4 text-danger">
                    <i class="fas fa-trash"></i> Șterge Programare
                </h2>

                <div class="alert alert-warning" role="alert">
                    <i class="fas fa-exclamation-triangle"></i>
                    <strong>Atenție!</strong> Ești sigur că vrei să ștergi această programare? Această acțiune nu poate
                    fi anulată.
                </div>

                <div class="booking-card">
                    <div class="booking-header">
                        <span class="booking-service">@Model.Service?.Name</span>
                        <span class="booking-status @Model.Status.ToString().ToLower()">
                            @(Model.Status.ToString() == "Confirmed" ? "Confirmată" :
                              Model.Status.ToString() == "Canceled" ? "Anulată" :
                              Model.Status.ToString() == "Finalized" ? "Finalizată" :
                              Model.Status.ToString())
                        </span>
                    </div>

                    <div class="booking-details mb-3">
                        <p>
                            <i class="fas fa-calendar-alt"></i>
                            <strong>Data:</strong> @Model.AppointmentDate.ToString("dddd, dd MMMM yyyy")
                        </p>
                        <p>
                            <i class="fas fa-clock"></i>
                            <strong>Ora:</strong> @Model.AppointmentTime.ToString("HH:mm")
                        </p>
                        <p>
                            <i class="fas fa-user"></i>
                            <strong>Frizer:</strong> @Model.Worker?.Name
                        </p>
                        <p>
                            <i class="fas fa-tag"></i>
                            <strong>Preț:</strong> @Model.Service?.Price RON
                        </p>
                    </div>

                    <form asp-action="Delete" style="margin: 0;">
                        <input type="hidden" asp-for="Id" />
                        <div class="booking-actions">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left"></i> Anulează
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-check"></i> Confirma Ștergerea
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
