@model BarberSalon.Models.Appointment

@{
    ViewData["Title"] = "Editare Programare";
}

<h1>@ViewData["Title"]</h1>

<hr />
<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card">
            <div class="card-body">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <input type="hidden" asp-for="Id" />

                    <div class="form-group mb-3">
                        <label for="UserId" class="form-label">ID Utilizator:</label>
                        <input id="UserId" name="UserId" value="@Model.UserId" type="number" class="form-control" required />
                        <span class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label for="serviceSelect" class="form-label">Selectați Serviciul:</label>
                        <select id="serviceSelect" name="ServiceId" class="form-control" asp-items="ViewBag.ServiceId" required>
                            <option value="">-- Alege un serviciu --</option>
                        </select>
                        <span class="text-danger" id="serviceError"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label for="workerSelect" class="form-label">Selectați Frizerul:</label>
                        <select id="workerSelect" name="WorkerId" class="form-control" asp-items="ViewBag.WorkerId" required>
                            <option value="">-- Alege un frizer --</option>
                        </select>
                        <span class="text-danger" id="workerError"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label for="appointmentDate" class="form-label">Data Programării:</label>
                        <input id="appointmentDate" name="AppointmentDate" type="date" class="form-control" value="@Model.AppointmentDate.ToString("yyyy-MM-dd")" required />
                        <span class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label for="timeSelect" class="form-label">Ora Programării (Ore Disponibile):</label>
                        <select id="timeSelect" name="AppointmentTime" class="form-control" required>
                            <option value="@Model.AppointmentTime.ToString("HH:mm")">@Model.AppointmentTime.ToString("HH:mm")</option>
                        </select>
                        <span class="text-danger" id="timeError"></span>
                    </div>

                    <div class="form-group mb-3">
                        <button type="submit" class="btn btn-primary btn-lg w-100">Salvează Modificări</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Înapoi la Lista</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            var appointmentId = @Model.Id;
            var currentTime = '@Model.AppointmentTime.ToString("HH:mm")';

            // Set minimum date to today
            var today = new Date().toISOString().split('T')[0];
            $('#appointmentDate').attr('min', today);

            // Load available times when date or worker are selected
            $('#workerSelect, #appointmentDate').change(function() {
                var workerId = $('#workerSelect').val();
                var dateStr = $('#appointmentDate').val();

                if (workerId && dateStr) {
                    $.ajax({
                        url: '@Url.Action("GetAvailableTimes", "Appointments")',
                        type: 'GET',
                        data: { workerId: workerId, date: dateStr, appointmentId: appointmentId },
                        success: function(times) {
                            var timeSelect = $('#timeSelect');
                            timeSelect.empty();

                            if (times && times.length > 0) {
                                // Add current time if available
                                if (times.includes(currentTime)) {
                                    timeSelect.append(new Option(currentTime + ' (current)', currentTime, false, true));
                                    times = times.filter(t => t !== currentTime);
                                    timeSelect.append(new Option('-- Alege o oră --', '', false, false));
                                    times.forEach(function(time) {
                                        timeSelect.append(new Option(time, time));
                                    });
                                } else {
                                    timeSelect.append(new Option('-- Alege o oră --', '', false, false));
                                    times.forEach(function(time) {
                                        timeSelect.append(new Option(time, time));
                                    });
                                }
                                timeSelect.prop('disabled', false);
                            } else {
                                timeSelect.append(new Option('Nicio oră disponibilă', ''));
                                timeSelect.prop('disabled', true);
                            }
                        },
                        error: function() {
                            $('#timeError').text('Error loading available times');
                            var timeSelect = $('#timeSelect');
                            timeSelect.empty();
                            timeSelect.append(new Option('Error loading times', ''));
                            timeSelect.prop('disabled', true);
                        }
                    });
                }
            });

            // Load available times on page load
            var workerId = $('#workerSelect').val();
            var dateStr = $('#appointmentDate').val();
            if (workerId && dateStr) {
                $('#workerSelect').trigger('change');
            }
        });
    </script>
}
