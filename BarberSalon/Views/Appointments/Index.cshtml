@model IEnumerable<BarberSalon.Models.Appointment>

@{
    ViewData["Title"] = "Programări";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Adaugă Programare</a>
</p>

<div class="table-responsive">
    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID Utilizator</th>
                <th>Serviciu</th>
                <th>Frizer</th>
                <th>Data</th>
                <th>Ora</th>
                <th>Status</th>
                <th>Acțiuni</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model) {
            <tr>
                <td>@item.UserId</td>
                <td>@item.Service.Name</td>
                <td>@item.Worker.Name</td>
                <td>@item.AppointmentDate.ToString("dd/MM/yyyy")</td>
                <td>@item.AppointmentTime.ToString("HH:mm")</td>
                <td>
                    @if (item.Status.ToString() == "Confirmed")
                    {
                        <span class="badge bg-success">Confirmată</span>
                    }
                    else if (item.Status.ToString() == "Canceled")
                    {
                        <span class="badge bg-danger">Anulată</span>
                    }
                    else if (item.Status.ToString() == "Finalized")
                    {
                        <span class="badge bg-info">Finalizată</span>
                    }
                    else
                    {
                        <span class="badge bg-warning">@item.Status</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editează</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Detalii</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Șterge</a>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>
