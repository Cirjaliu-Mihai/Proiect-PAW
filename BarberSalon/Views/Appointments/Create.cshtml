@model BarberSalon.Models.Appointment

@{
    ViewData["Title"] = "Programare";
}

<h1>@ViewData["Title"]</h1>

<hr />
<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="form-group mb-3">
                        <label asp-for="UserId" class="form-label">ID Utilizator:</label>
                        <input asp-for="UserId" class="form-control" placeholder="" required />
                        <span asp-validation-for="UserId" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label for="serviceSelect" class="form-label">Service:</label>
                        <select id="serviceSelect" name="ServiceId" class="form-control" required>
                            <option value="">-- Alege un serviciu --</option>
                        </select>
                        <span class="text-danger" id="serviceError"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label for="workerSelect" class="form-label">Frizerul:</label>
                        <select id="workerSelect" name="WorkerId" class="form-control" required>
                            <option value="">-- Alege un frizer --</option>
                        </select>
                        <span class="text-danger" id="workerError"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label for="appointmentDate" class="form-label">Selectați Data:</label>
                        <input id="appointmentDate" name="AppointmentDate" type="date" class="form-control" required />
                        <span class="text-danger" id="dateError"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label for="timeSelect" class="form-label">Ore Disponibile:</label>
                        <select id="timeSelect" name="AppointmentTime" class="form-control" required disabled>
                            <option value="">-- Alege mai întâi data și frizerul --</option>
                        </select>
                        <span class="text-danger" id="timeError"></span>
                    </div>

                   

                    <div class="form-group mb-0">
                        <button type="submit" class="btn btn-warning btn-lg w-100">
                            <i class="fas fa-check"></i> Confirmă Programarea
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Înapoi la Lista</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            // Set minimum date to today
            var today = new Date().toISOString().split('T')[0];
            $('#appointmentDate').attr('min', today);

            // Populate services by name
            $.ajax({
                url: '@Url.Action("GetServices", "Appointments")',
                type: 'GET',
                success: function(data) {
                    var serviceSelect = $('#serviceSelect');
                    if (data && data.length > 0) {
                        data.forEach(function(service) {
                            serviceSelect.append(new Option(service.name, service.id));
                        });
                    } else {
                        $('#serviceError').text('No services available');
                    }
                },
                error: function() {
                    $('#serviceError').text('Error loading services');
                }
            });

            // Populate workers by name
            $.ajax({
                url: '@Url.Action("GetWorkers", "Appointments")',
                type: 'GET',
                success: function(data) {
                    var workerSelect = $('#workerSelect');
                    if (data && data.length > 0) {
                        data.forEach(function(worker) {
                            workerSelect.append(new Option(worker.name, worker.id));
                        });
                    } else {
                        $('#workerError').text('No workers available');
                    }
                },
                error: function() {
                    $('#workerError').text('Error loading workers');
                }
            });

            // Load available times when date and worker are selected
            $('#workerSelect, #appointmentDate').change(function() {
                var workerId = $('#workerSelect').val();
                var dateStr = $('#appointmentDate').val();

                if (workerId && dateStr) {
                    var date = new Date(dateStr);
                    $.ajax({
                        url: '@Url.Action("GetAvailableTimes", "Appointments")',
                        type: 'GET',
                        data: { workerId: workerId, date: dateStr },
                        success: function(times) {
                            var timeSelect = $('#timeSelect');
                            timeSelect.empty();

                            if (times && times.length > 0) {
                                timeSelect.append(new Option('-- Alege o oră --', ''));
                                times.forEach(function(time) {
                                    timeSelect.append(new Option(time, time));
                                });
                                timeSelect.prop('disabled', false);
                            } else {
                                timeSelect.append(new Option('Nicio oră disponibilă', ''));
                                timeSelect.prop('disabled', true);
                            }
                        },
                        error: function() {
                            $('#timeError').text('Error loading available times');
                            var timeSelect = $('#timeSelect');
                            timeSelect.empty();
                            timeSelect.append(new Option('Error loading times', ''));
                            timeSelect.prop('disabled', true);
                        }
                    });
                } else {
                    var timeSelect = $('#timeSelect');
                    timeSelect.empty();
                    timeSelect.append(new Option('-- Alege mai întâi data și frizerul --', ''));
                    timeSelect.prop('disabled', true);
                }
            });
        });
    </script>
}
