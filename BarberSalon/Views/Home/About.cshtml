@{
    ViewData["Title"] = "Despre Noi";
}

@section CustomStyles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/about.css" asp-append-version="true" />
}

<section class="about-section py-5">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col-md-6">
                <h2>Povestea Noastră</h2>
                <p>
                    Mihai's Salon a fost înființat în 2020 cu o simplă viziune: să
                    ofere servicii de frizerie de o calitate excepțională în inima
                    comunității noastre. Ceea ce a început ca o mică visă s-a
                    dezvoltat într-o afacere prosperă cu o echipă dedicată de
                    profesioniști.
                </p>
                <p>
                    Fiecare membru al echipei noastre aduce expertiza și pasiunea sa
                    pentru meșteșug, asigurând că fiecare client primește atenția pe
                    care o merită. Credem că o bună frizie nu este doar despre păr -
                    este despre a da clienților noștri încredere și satisfacție.
                </p>
            </div>
            <div class="col-md-6">
                <img
                    src="~/assets/images/logo.png"
                    alt="Mihai's Salon"
                    class="img-fluid rounded about-image"
                />
            </div>
        </div>

        <div class="row mb-5">
            <div class="col-md-6">
                <div class="value-card">
                    <h3><i class="fas fa-bullseye"></i> Misiunea Noastră</h3>
                    <p>
                        Să oferim servicii de frizerie de cea mai înaltă calitate,
                        creând o experiență memorabilă pentru fiecare client și
                        construind relații pe baza încrederii și respectului mutual.
                    </p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="value-card">
                    <h3><i class="fas fa-heart"></i> Valorile Noastre</h3>
                    <p>
                        Excelență, integritate, inovație și grijă pentru client. Aceste
                        valori ghidează fiecare decizie pe care o luăm și fiecare
                        serviciu pe care îl oferim.
                    </p>
                </div>
            </div>
        </div>

        <div class="why-choose-us">
            <h2 class="text-center mb-5">De Ce Să Ne Alegi</h2>
            <div class="row">
                <div class="col-md-4 text-center mb-4">
                    <div class="choice-item">
                        <i class="fas fa-star"></i>
                        <h4>Profesioniști Experimentați</h4>
                        <p>
                            Echipa noastră are peste 50 de ani de experiență combinată în
                            industria frizeriei.
                        </p>
                    </div>
                </div>
                <div class="col-md-4 text-center mb-4">
                    <div class="choice-item">
                        <i class="fas fa-tools"></i>
                        <h4>Echipamente de Top</h4>
                        <p>
                            Folosim doar echipament și produse profesionale de cea mai
                            bună calitate.
                        </p>
                    </div>
                </div>
                <div class="col-md-4 text-center mb-4">
                    <div class="choice-item">
                        <i class="fas fa-smile"></i>
                        <h4>Atmosferă Prietenoasă</h4>
                        <p>
                            Salonul nostru este un loc unde poți relaxa și simți că ești
                            bun-venit.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

